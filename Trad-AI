<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALTBOT — Trading Intelligence</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap');

  :root {
    --bg: #0a0a0f;
    --bg2: #111118;
    --bg3: #16161f;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.13);
    --text: #e8e8f0;
    --muted: #6b6b80;
    --accent: #7c6bff;
    --accent2: #b09fff;
    --green: #00e5a0;
    --green2: rgba(0,229,160,0.12);
    --red: #ff4d6d;
    --red2: rgba(255,77,109,0.12);
    --amber: #fbbf24;
    --amber2: rgba(251,191,36,0.12);
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid noise texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(124,107,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,107,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .app { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 0 20px 60px; }

  /* HEADER */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .logo {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text);
  }
  .logo span { color: var(--accent2); }

  .header-right { display: flex; align-items: center; gap: 16px; }

  .live-dot {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: 11px; color: var(--green);
    letter-spacing: 0.06em;
  }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: blink 2s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .last-update { font-family: var(--mono); font-size: 11px; color: var(--muted); }

  /* STATUS BAR */
  .status-bar {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin-bottom: 24px;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .stat-label { font-size: 10px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; font-family: var(--mono); margin-bottom: 6px; }
  .stat-val { font-size: 22px; font-weight: 500; font-family: var(--mono); }
  .stat-sub { font-size: 11px; color: var(--muted); margin-top: 3px; }
  .g { color: var(--green); }
  .r { color: var(--red); }
  .a { color: var(--amber); }
  .p { color: var(--accent2); }

  /* MAIN LAYOUT */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 16px;
    align-items: start;
  }

  @media(max-width: 860px) { .main-grid { grid-template-columns: 1fr; } }

  /* SECTION */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--mono); font-size: 11px; color: var(--accent2);
    letter-spacing: 0.1em; text-transform: uppercase;
  }

  /* ASSET LIST */
  .asset-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }

  .asset-row {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 48px 1fr auto auto;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .asset-row::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
    background: transparent;
    transition: background 0.2s;
  }
  .asset-row.buy::before { background: var(--green); }
  .asset-row.sell::before { background: var(--red); }
  .asset-row.hold::before { background: var(--amber); }
  .asset-row:hover { border-color: var(--border2); background: var(--bg3); }
  .asset-row.active { border-color: var(--accent); background: var(--bg3); }

  .asset-icon {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    background: var(--bg3); border: 1px solid var(--border2);
    color: var(--accent2);
  }

  .asset-info .name { font-weight: 500; font-size: 14px; }
  .asset-info .full { font-size: 11px; color: var(--muted); margin-top: 1px; }

  .asset-price-block { text-align: right; }
  .asset-price-block .price { font-family: var(--mono); font-size: 14px; font-weight: 500; }
  .asset-price-block .chg { font-family: var(--mono); font-size: 11px; margin-top: 2px; }

  .signal-badge {
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    padding: 4px 10px; border-radius: 4px; letter-spacing: 0.08em;
    min-width: 64px; text-align: center;
  }
  .badge-buy { background: var(--green2); color: var(--green); border: 1px solid rgba(0,229,160,0.3); }
  .badge-sell { background: var(--red2); color: var(--red); border: 1px solid rgba(255,77,109,0.3); }
  .badge-hold { background: var(--amber2); color: var(--amber); border: 1px solid rgba(251,191,36,0.3); }

  /* CHART MINI */
  .mini-chart { height: 40px; margin-top: 6px; }

  /* STRATEGY PANEL */
  .strategy-panel {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px;
    margin-bottom: 16px;
  }

  .indicator-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid var(--border);
  }
  .indicator-row:last-child { border-bottom: none; }
  .ind-name { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .ind-val { font-family: var(--mono); font-size: 13px; font-weight: 500; }
  .ind-bar-wrap { width: 80px; height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
  .ind-bar { height: 100%; border-radius: 2px; transition: width 0.5s; }

  .pattern-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .pattern-tag {
    font-family: var(--mono); font-size: 10px; padding: 3px 9px; border-radius: 4px;
    background: rgba(124,107,255,0.12); color: var(--accent2); border: 1px solid rgba(124,107,255,0.25);
  }

  /* SIGNAL CARD — main action */
  .signal-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    position: sticky;
    top: 20px;
  }

  .signal-card.buy-card { border-color: rgba(0,229,160,0.3); }
  .signal-card.sell-card { border-color: rgba(255,77,109,0.3); }
  .signal-card.hold-card { border-color: rgba(251,191,36,0.2); }

  .signal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .signal-asset { font-family: var(--mono); font-size: 20px; font-weight: 600; }
  .signal-type { font-family: var(--mono); font-size: 22px; font-weight: 600; }

  .signal-details {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px; margin-bottom: 16px;
  }
  .sig-detail {
    background: var(--bg3); border-radius: 6px; padding: 10px 12px;
  }
  .sig-detail .lbl { font-size: 10px; color: var(--muted); font-family: var(--mono); text-transform: uppercase; margin-bottom: 4px; }
  .sig-detail .vl { font-family: var(--mono); font-size: 14px; font-weight: 500; }

  .confidence-bar-wrap {
    background: rgba(255,255,255,0.06); border-radius: 3px; height: 6px;
    overflow: hidden; margin-bottom: 6px;
  }
  .confidence-bar { height: 100%; border-radius: 3px; background: var(--accent); transition: width 0.6s; }

  .conf-label { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 14px; }

  /* ACTION BUTTONS */
  .action-buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }

  .btn {
    padding: 14px; border-radius: 8px; border: none; cursor: pointer;
    font-family: var(--mono); font-size: 13px; font-weight: 600;
    letter-spacing: 0.06em; transition: all 0.15s; text-align: center;
  }
  .btn-execute {
    background: var(--green); color: #000;
  }
  .btn-execute:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn-ignore {
    background: var(--bg3); color: var(--muted);
    border: 1px solid var(--border2);
  }
  .btn-ignore:hover { color: var(--text); border-color: var(--border2); }
  .btn-execute:disabled, .btn-ignore:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .btn-sell-execute { background: var(--red); color: #fff; }
  .btn-sell-execute:hover { opacity: 0.85; transform: translateY(-1px); }

  .kraken-note {
    font-size: 11px; color: var(--muted); text-align: center;
    padding: 8px; background: var(--bg3); border-radius: 6px;
    border: 1px solid var(--border);
    font-family: var(--mono);
  }
  .kraken-note a { color: var(--accent2); text-decoration: none; }

  /* LOG */
  .log-section {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; margin-top: 0;
  }
  .log-entry {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 12px;
  }
  .log-entry:last-child { border-bottom: none; }
  .log-time { font-family: var(--mono); font-size: 10px; color: var(--muted); min-width: 48px; margin-top: 1px; }
  .log-icon { font-size: 12px; min-width: 14px; }
  .log-msg { color: var(--text); line-height: 1.4; }
  .log-empty { color: var(--muted); font-family: var(--mono); font-size: 12px; text-align: center; padding: 20px 0; }

  /* RISK BOX */
  .risk-box {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 14px; margin-bottom: 14px;
  }
  .risk-title { font-family: var(--mono); font-size: 10px; color: var(--amber); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
  .risk-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 12px; }
  .risk-row .rl { color: var(--muted); }
  .risk-row .rv { font-family: var(--mono); font-weight: 500; }

  /* AI ANALYSIS */
  .ai-section {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; margin-top: 16px;
  }
  .ai-text { font-size: 13px; line-height: 1.7; color: var(--text); }
  .ai-loading { color: var(--muted); font-family: var(--mono); font-size: 12px; }

  /* TOAST */
  .toast {
    position: fixed; bottom: 24px; right: 24px;
    background: var(--bg3); border: 1px solid var(--border2);
    border-radius: 8px; padding: 14px 20px;
    font-family: var(--mono); font-size: 13px; color: var(--text);
    z-index: 1000; transform: translateY(80px); opacity: 0;
    transition: all 0.3s; max-width: 320px;
  }
  .toast.show { transform: translateY(0); opacity: 1; }
  .toast.toast-ok { border-color: rgba(0,229,160,0.4); }
  .toast.toast-skip { border-color: rgba(255,77,109,0.3); }

  /* REFRESH BTN */
  .refresh-btn {
    background: none; border: 1px solid var(--border2); color: var(--muted);
    font-family: var(--mono); font-size: 11px; padding: 5px 12px; border-radius: 5px;
    cursor: pointer; transition: all 0.15s; letter-spacing: 0.04em;
  }
  .refresh-btn:hover { color: var(--text); border-color: var(--border2); }
  .refresh-btn.spinning { animation: spin 1s linear infinite; }
  @keyframes spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

  select {
    background: var(--bg3); border: 1px solid var(--border2); color: var(--text);
    font-family: var(--mono); font-size: 11px; padding: 5px 10px; border-radius: 5px;
    cursor: pointer; outline: none;
  }

  .divider { height: 1px; background: var(--border); margin: 16px 0; }

  canvas { display: block; }

  .no-signal {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 12px;
    padding: 30px; text-align: center; color: var(--muted); font-family: var(--mono); font-size: 13px;
  }

  /* SOCIAL SENTIMENT */
  .social-section {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; margin-top: 16px;
  }
  .social-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 12px 0;
  }
  @media(max-width: 600px) { .social-grid { grid-template-columns: repeat(2, 1fr); } }
  .social-card {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 12px; text-align: center;
  }
  .social-icon { font-size: 18px; margin-bottom: 4px; }
  .social-name { font-family: var(--mono); font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 6px; }
  .social-score { font-family: var(--mono); font-size: 18px; font-weight: 600; }
  .social-label { font-size: 10px; margin-top: 3px; font-family: var(--mono); }
  .sentiment-bar-wrap { height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; margin: 10px 0 6px; }
  .sentiment-bar { height: 100%; border-radius: 2px; transition: width 0.6s; }
  .sentiment-summary {
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--mono); font-size: 11px;
  }
  .social-feed { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
  .feed-item {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    padding: 8px 10px; font-size: 12px; line-height: 1.5;
  }
  .feed-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 3px; }
  .feed-source { font-family: var(--mono); font-size: 10px; color: var(--accent2); }
  .feed-time { font-family: var(--mono); font-size: 10px; color: var(--muted); }
  .feed-sent { font-size: 10px; padding: 1px 7px; border-radius: 3px; font-family: var(--mono); }
  .fs-pos { background: var(--green2); color: var(--green); }
  .fs-neg { background: var(--red2); color: var(--red); }
  .fs-neu { background: var(--amber2); color: var(--amber); }
  .social-alert {
    background: rgba(255,77,109,0.08); border: 1px solid rgba(255,77,109,0.25);
    border-radius: 6px; padding: 8px 12px; font-size: 12px; color: var(--red);
    margin-top: 8px; font-family: var(--mono); display: none;
  }
  .social-alert.show { display: block; }
  .overall-sentiment {
    display: flex; align-items: center; gap: 10px; padding: 10px 14px;
    background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 12px;
  }
  .os-label { font-family: var(--mono); font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
  .os-val { font-family: var(--mono); font-size: 16px; font-weight: 600; }
  .os-impact { font-family: var(--mono); font-size: 11px; margin-left: auto; }
</style>
</head>
<body>

<div class="app">

  <header>
    <div class="logo">ALT<span>BOT</span> <span style="color:var(--muted);font-size:13px;font-weight:400">/ Kraken</span></div>
    <div class="header-right">
      <div class="live-dot"><span class="dot"></span> LIVE</div>
      <div class="last-update" id="last-update">--:--:--</div>
      <button class="refresh-btn" onclick="refreshAll()" id="refresh-btn">↻ AGGIORNA</button>
    </div>
  </header>

  <div class="status-bar" id="status-bar">
    <div class="stat-card"><div class="stat-label">Segnali BUY</div><div class="stat-val g" id="s-buy">—</div><div class="stat-sub">asset pronti</div></div>
    <div class="stat-card"><div class="stat-label">Segnali SELL</div><div class="stat-val r" id="s-sell">—</div><div class="stat-sub">uscire ora</div></div>
    <div class="stat-card"><div class="stat-label">Mercato</div><div class="stat-val a" id="s-market">—</div><div class="stat-sub">sentiment altcoin</div></div>
    <div class="stat-card"><div class="stat-label">Social Alert</div><div class="stat-val r" id="s-social">0</div><div class="stat-sub">pump/dump/viral</div></div>
    <div class="stat-card"><div class="stat-label">Trade eseguiti</div><div class="stat-val p" id="s-trades">0</div><div class="stat-sub">questa sessione</div></div>
  </div>

  <div class="main-grid">

    <!-- LEFT: asset list + strategy -->
    <div>
      <div class="section-header">
        <div class="section-title">// ALTCOIN WATCHLIST</div>
        <div style="display:flex;gap:8px;align-items:center">
          <select id="sort-select" onchange="sortAssets(this.value)">
            <option value="signal">Per segnale</option>
            <option value="chg">Per variazione</option>
            <option value="rsi">Per RSI</option>
          </select>
        </div>
      </div>

      <div class="asset-list" id="asset-list">
        <div style="color:var(--muted);font-family:var(--mono);font-size:12px;padding:20px;text-align:center">
          Caricamento dati da CoinGecko…
        </div>
      </div>

      <div class="section-header" style="margin-top:20px">
        <div class="section-title">// ANALISI STRATEGIA — <span id="strategy-asset">seleziona asset</span></div>
      </div>

      <div class="strategy-panel" id="strategy-panel">
        <div style="color:var(--muted);font-family:var(--mono);font-size:12px;text-align:center;padding:20px">
          Seleziona un asset per vedere l'analisi tecnica
        </div>
      </div>

      <div class="ai-section" id="ai-section" style="display:none">
        <div class="section-title" style="margin-bottom:12px">// AI ANALYSIS — TECNICO + SOCIAL</div>
        <div id="ai-output" class="ai-loading">—</div>
      </div>

      <div class="social-section" id="social-section" style="display:none">
        <div class="section-title" style="margin-bottom:12px">// SOCIAL SENTIMENT — <span id="social-asset-label">—</span></div>

        <div class="overall-sentiment" id="overall-sentiment">
          <div>
            <div class="os-label">Sentiment globale</div>
            <div class="os-val" id="os-val">—</div>
          </div>
          <div style="flex:1;margin:0 12px">
            <div class="sentiment-bar-wrap" style="margin:0">
              <div class="sentiment-bar" id="os-bar" style="width:50%"></div>
            </div>
          </div>
          <div class="os-impact" id="os-impact">—</div>
        </div>

        <div class="social-grid" id="social-grid">
          <div class="social-card">
            <div class="social-icon">𝕏</div>
            <div class="social-name">X / Twitter</div>
            <div class="social-score" id="sc-twitter">—</div>
            <div class="social-label" id="sl-twitter" style="color:var(--muted)">caricamento</div>
            <div class="social-vol" id="sv-twitter" style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:3px">—</div>
          </div>
          <div class="social-card">
            <div class="social-icon" style="color:#ff4500">●</div>
            <div class="social-name">Reddit</div>
            <div class="social-score" id="sc-reddit">—</div>
            <div class="social-label" id="sl-reddit" style="color:var(--muted)">caricamento</div>
            <div class="social-vol" id="sv-reddit" style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:3px">—</div>
          </div>
          <div class="social-card">
            <div class="social-icon" style="color:#229ed9">✈</div>
            <div class="social-name">Telegram</div>
            <div class="social-score" id="sc-telegram">—</div>
            <div class="social-label" id="sl-telegram" style="color:var(--muted)">caricamento</div>
            <div class="social-vol" id="sv-telegram" style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:3px">—</div>
          </div>
          <div class="social-card">
            <div class="social-icon" style="color:#5865f2">◈</div>
            <div class="social-name">Discord</div>
            <div class="social-score" id="sc-discord">—</div>
            <div class="social-label" id="sl-discord" style="color:var(--muted)">caricamento</div>
            <div class="social-vol" id="sv-discord" style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:3px">—</div>
          </div>
          <div class="social-card">
            <div class="social-icon" style="color:#ff0000">▶</div>
            <div class="social-name">YouTube</div>
