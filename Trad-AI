function renderSocialSentiment(data, meta) {
  function scoreColor(s) {
    if (s >= 65) return 'var(--green)';
    if (s <= 40) return 'var(--red)';
    return 'var(--amber)';
  }
  function labelClass(l) {
    if (l === 'BULLISH' || l === 'MOLTO BULLISH') return 'g';
    if (l === 'BEARISH' || l === 'MOLTO BEARISH') return 'r';
    return 'a';
  }

  // Render all 6 platforms
  ['twitter','reddit','telegram','discord','youtube','news'].forEach(platform => {
    const d = data[platform];
    if (!d) return;
    const scEl = document.getElementById('sc-' + platform);
    const slEl = document.getElementById('sl-' + platform);
    const svEl = document.getElementById('sv-' + platform);
    if (scEl) { scEl.textContent = d.score; scEl.style.color = scoreColor(d.score); }
    if (slEl) { slEl.textContent = d.label; slEl.className = 'social-label ' + labelClass(d.label); }
    if (svEl) svEl.textContent = d.volume || d.nota || '—';
  });

  // Overall
  const osEl = document.getElementById('os-val');
  osEl.textContent = data.overall_label;
  osEl.style.color = scoreColor(data.overall);
  const barEl = document.getElementById('os-bar');
  barEl.style.width = data.overall + '%';
  barEl.style.background = scoreColor(data.overall);
  const impactEl = document.getElementById('os-impact');
  impactEl.textContent = 'Impatto: ' + (data.market_impact || '—');
  impactEl.style.color = data.market_impact === 'ALTO' ? 'var(--red)' : data.market_impact === 'MEDIO' ? 'var(--amber)' : 'var(--muted)';

  // Alert
  const alertEl = document.getElementById('social-alert');
  if (data.alert && data.alert_reason) {
    alertEl.classList.add('show');
    alertEl.textContent = '⚠ ALERT SOCIAL: ' + data.alert_reason;
    const sAlerts = parseInt(document.getElementById('s-social').textContent) || 0;
    document.getElementById('s-social').textContent = sAlerts + 1;
  }

  // Social vs Technical note
  if (data.social_vs_technical) {
    const existing = document.getElementById('svt-box');
    if (existing) existing.remove();
    const note = document.createElement('div');
    note.id = 'svt-box';
    note.style.cssText = 'background:rgba(124,107,255,0.08);border:1px solid rgba(124,107,255,0.2);border-radius:6px;padding:10px 12px;margin-top:10px;font-size:12px;color:var(--text);line-height:1.6';
    note.innerHTML = '<span style="font-family:var(--mono);font-size:10px;color:var(--accent2);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em">▸ Social vs Tecnico</span>' + data.social_vs_technical;
    document.getElementById('social-feed').before(note);
  }

  // Feed
  const sentMap = { pos: 'fs-pos', neg: 'fs-neg', neu: 'fs-neu' };
  const sentLabel = { pos: '▲ POS', neg: '▼ NEG', neu: '— NEU' };
  document.getElementById('social-feed').innerHTML = (data.feed || []).map(item => `
    <div class="feed-item">
      <div class="feed-meta">
        <span class="feed-source">${item.source}</span>
        <span class="feed-time">${item.time}</span>
        <span class="feed-sent ${sentMap[item.sentiment] || 'fs-neu'}">${sentLabel[item.sentiment] || '—'}</span>
      </div>
      <div style="color:var(--text);font-size:12px">${item.text}</div>
    </div>
  `).join('');

  // Store for AI
  marketData[meta.id].socialNote = data.social_vs_technical;
  marketData[meta.id].socialData = data;
}

