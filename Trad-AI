// ─── REFRESH ─────────────────────────────────────────────────────────────
async function refreshAll() {
  const btn = document.getElementById('refresh-btn');
  btn.classList.add('spinning');
  btn.disabled = true;
  try {
    const data = await fetchPrices();
    renderAssetList(data);
    document.getElementById('last-update').textContent = now();
    addLog('↻', 'Dati aggiornati da CoinGecko', 'p');
    if (selectedAsset && marketData[selectedAsset]) {
      const { raw, computed, meta } = marketData[selectedAsset];
      renderStrategyPanel(raw, computed, meta);
      renderSignalCard(raw, computed, meta);
    }
  } catch (e) {
    addLog('!', 'Errore aggiornamento dati: ' + e.message, 'r');
    showToast('Errore connessione CoinGecko', 'toast-skip');
  } finally {
    btn.classList.remove('spinning');
    btn.disabled = false;
  }
}

// ─── INIT ────────────────────────────────────────────────────────────────
async function init() {
  document.getElementById('last-update').textContent = '…';
  try {
    const data = await fetchPrices();
    renderAssetList(data);
    document.getElementById('last-update').textContent = now();
    // Auto-select first BUY signal
    const firstBuy = Object.values(marketData).find(d => d.computed.signal === 'buy');
    if (firstBuy) selectAsset(firstBuy.meta.id);
  } catch (e) {
    document.getElementById('asset-list').innerHTML =
      `<div style="color:var(--red);font-family:var(--mono);font-size:12px;padding:20px;text-align:center">
        Errore CoinGecko: ${e.message}<br><br>
        <button onclick="init()" style="background:none;border:1px solid var(--border2);color:var(--muted);font-family:var(--mono);font-size:11px;padding:6px 14px;border-radius:5px;cursor:pointer">↻ Riprova</button>
      </div>`;
  }

  // Auto-refresh ogni 60 secondi
  setInterval(refreshAll, 60000);
}

