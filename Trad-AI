// ─── TECHNICAL INDICATORS ───────────────────────────────────────────────
function calcRSI(prices, period = 14) {
  if (prices.length < period + 1) return 50;
  let gains = 0, losses = 0;
  for (let i = prices.length - period; i < prices.length; i++) {
    const d = prices[i] - prices[i - 1];
    if (d > 0) gains += d; else losses -= d;
  }
  const rs = gains / (losses || 0.001);
  return Math.round(100 - 100 / (1 + rs));
}

function calcEMA(prices, period) {
  const k = 2 / (period + 1);
  let ema = prices[0];
  for (let i = 1; i < prices.length; i++) ema = prices[i] * k + ema * (1 - k);
  return ema;
}

function calcMACD(prices) {
  if (prices.length < 26) return { macd: 0, signal: 0, hist: 0 };
  const ema12 = calcEMA(prices.slice(-26), 12);
  const ema26 = calcEMA(prices.slice(-26), 26);
  const macd = ema12 - ema26;
  const signal = macd * 0.8; // simplified
  const hist = macd - signal;
  return { macd: +macd.toFixed(4), signal: +signal.toFixed(4), hist: +hist.toFixed(4) };
}

function detectPatterns(prices, volumes) {
  const patterns = [];
  const n = prices.length;
  if (n < 5) return patterns;
  const last = prices[n - 1], prev = prices[n - 2], prev2 = prices[n - 3];
  const avgVol = volumes.slice(-7).reduce((a, b) => a + b, 0) / 7;
  const lastVol = volumes[n - 1];

  if (last > prev && prev < prev2) patterns.push('Hammer');
  if (last < prev && last > prev2 * 0.98) patterns.push('Bearish Engulf');
  if (Math.abs(last - prev) / prev < 0.005) patterns.push('Doji');
  if (lastVol > avgVol * 1.5) patterns.push('Volume Spike');
  if (last > prices.slice(-7).reduce((a, b) => Math.max(a, b), 0) * 0.99) patterns.push('Breakout');
  if (last < prices.slice(-7).reduce((a, b) => Math.min(a, b), Infinity) * 1.01) patterns.push('Support Test');
  return patterns;
}

function computeSignal(rsi, macd, chg24h, chg7d) {
  let score = 0;
  if (rsi < 35) score += 2;
  else if (rsi < 45) score += 1;
  else if (rsi > 70) score -= 2;
  else if (rsi > 60) score -= 1;
  if (macd.hist > 0) score += 1;
  else score -= 1;
  if (chg24h > 3) score += 1;
  else if (chg24h < -5) score -= 1;
  if (chg7d > 5) score += 1;
  else if (chg7d < -10) score -= 1;
  if (score >= 2) return 'buy';
  if (score <= -2) return 'sell';
  return 'hold';
}

function computeConfidence(rsi, macd, signal) {
  let c = 50;
  if (signal === 'buy') {
    c += Math.max(0, 40 - rsi);
    if (macd.hist > 0) c += 10;
  } else if (signal === 'sell') {
    c += Math.max(0, rsi - 60);
    if (macd.hist < 0) c += 10;
  }
  return Math.min(95, Math.max(30, Math.round(c)));
}

// ─── PROCESS DATA ────────────────────────────────────────────────────────
function processAsset(raw) {
  const sparkline = raw.sparkline_in_7d?.price || [];
  const prices = sparkline.length > 0 ? sparkline : [raw.current_price];
  const vols = Array(prices.length).fill(raw.total_volume || 1000000);

  const rsi = calcRSI(prices);
  const macd = calcMACD(prices);
  const patterns = detectPatterns(prices, vols);
  const chg24h = raw.price_change_percentage_24h || 0;
  const chg7d = raw.price_change_percentage_7d_in_currency || 0;
  const signal = computeSignal(rsi, macd, chg24h, chg7d);
  const confidence = computeConfidence(rsi, macd, signal);

  const entry = +(raw.current_price * 0.99).toFixed(6);
  const stop = +(raw.current_price * (signal === 'buy' ? 0.93 : 1.06)).toFixed(6);
  const target = +(raw.current_price * (signal === 'buy' ? 1.18 : 0.88)).toFixed(6);

  return { rsi, macd, patterns, chg24h, chg7d, signal, confidence, entry, stop, target, prices, sparkline };
}

// ─── FORMAT ──────────────────────────────────────────────────────────────
function fmtPrice(p) {
  if (p >= 1000) return '$' + p.toLocaleString('en-US', { maximumFractionDigits: 2 });
  if (p >= 1) return '$' + p.toFixed(3);
  return '$' + p.toFixed(6);
}
function fmtPct(n) { return (n >= 0 ? '+' : '') + n.toFixed(2) + '%'; }
function now() {
