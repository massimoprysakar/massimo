// ─── KRAKEN URL ──────────────────────────────────────────────────────────
function buildKrakenUrl(meta, price, signal) {
  // Kraken Pro format: /app/trade/SOL-USD (dash, not slash, not concatenated)
  const pair = meta.kraken.replace('/', '-'); // SOL/USD → SOL-USD
  const side = signal === 'sell' ? 'sell' : 'buy';
  // Use Kraken basic trade URL — most reliable format across sessions
  return `https://pro.kraken.com/app/trade/${pair}`;
}

// ─── EXECUTE / IGNORE ────────────────────────────────────────────────────
function executeOrder(id) {
  const { meta, raw, computed } = marketData[id];
  // URL built fresh at click time — never stale
  const freshUrl = buildKrakenUrl(meta, raw.current_price, computed.signal);
  tradeCount++;
  document.getElementById('s-trades').textContent = tradeCount;
  addLog('✓', `${computed.signal.toUpperCase()} ${meta.sym} @ ${fmtPrice(raw.current_price)} — apertura Kraken ${meta.kraken}`, 'g');
  showToast(`✓ Apertura Kraken: ${computed.signal.toUpperCase()} ${meta.sym}`, 'toast-ok');
  setTimeout(() => window.open(freshUrl, '_blank'), 250);
}

function ignoreSignal(id) {
  const { meta, computed } = marketData[id];
  addLog('✕', `Segnale ${computed.signal.toUpperCase()} ${meta.sym} ignorato`, 'r');
  showToast(`✕ Segnale ${meta.sym} ignorato`, 'toast-skip');
}

// ─── LOG ─────────────────────────────────────────────────────────────────
function addLog(icon, msg, cls) {
  logEntries.unshift({ icon, msg, cls, time: now() });
  if (logEntries.length > 20) logEntries.pop();
  renderLog();
}

function renderLog() {
  if (logEntries.length === 0) {
    document.getElementById('log-list').innerHTML = '<div class="log-empty">— nessun trade questa sessione —</div>';
    return;
  }
  document.getElementById('log-list').innerHTML = logEntries.map(e => `
    <div class="log-entry">
      <div class="log-time">${e.time}</div>
      <div class="log-icon ${e.cls}">${e.icon}</div>
      <div class="log-msg">${e.msg}</div>
    </div>
  `).join('');
}

// ─── TOAST ───────────────────────────────────────────────────────────────
